# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- IDE / editors ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Output data ---
# Local scrape outputs are excluded by default so a careless `git add .`
# during development doesn't commit megabytes of test data. The workflow's
# publish job commits the canonical run under data/scrapers/ and
# data/unified/, so we un-ignore those two subtrees explicitly.
data/**/*.json
data/**/*.json.tmp
data/**/*.jsonl
!data/.gitkeep
!data/scrapers/*.json
!data/unified/*.json

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Playwright ---
playwright-report/
test-results/

# --- Logs ---
*.log
