# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- IDE / editors ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Output data ---
# Local scrape outputs (developer-side `mkdir -p data && python xxx.py
# --out data/foo.json`) shouldn't accidentally land in commits on main.
# The workflow doesn't commit to main/data/ either -- it force-pushes
# to a separate `data` branch, which is decoupled from main and not
# affected by this rule. So we keep the rule strict here.
data/**/*.json
data/**/*.json.tmp
data/**/*.jsonl
!data/.gitkeep

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Playwright ---
playwright-report/
test-results/

# --- Logs ---
*.log
